# Copy to .env and fill in values

DATABASE_URL=sqlite:///./afrisale.db

# Vertex AI (GCP inference path)
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCP_MODEL=gemini-2.5-flash
# Absolute path to service account json key (or use gcloud ADC login)
GOOGLE_APPLICATION_CREDENTIALS=

# Normalized phone matching inbound webhook "from" (include country code, e.g. +256...)
OWNER_PHONE=

# Africa's Talking (optional for local dev — use SKIP_SMS_SEND=true in .env to log only)
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=
# AT_BASE_URL=https://api.africastalking.com/version1/messaging

# Gemini model id (default matches plan)
GEMINI_MODEL=gemini-2.5-flash

# LLM settings
LLM_TIMEOUT_SECONDS=30
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BACKOFF_SECONDS=0.8

# If true, outbound SMS is logged instead of sent
SKIP_SMS_SEND=false

# Twilio WhatsApp (inbound POST /api/webhook/whatsapp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox default; override for production WhatsApp sender
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Cloud Storage bucket for catalog and inbound media
GCS_BUCKET_PRODUCTS=
GCS_SIGNED_URL_TTL_SECONDS=86400

# Vertex AI Vector Search (Matching Engine) for image/text similarity
VERTEX_VECTOR_INDEX_ID=
VERTEX_VECTOR_INDEX_ENDPOINT_ID=
VERTEX_VECTOR_DEPLOYED_INDEX_ID=
VERTEX_VECTOR_DIMENSIONS=1408
VERTEX_EMBEDDING_MODEL=multimodalembedding@001

# Inbound image limits
IMAGE_MAX_BYTES=10485760
IMAGE_ALLOWED_MIMES=image/jpeg,image/png,image/webp,image/heic,image/heif

# Image matching thresholds
IMAGE_MATCH_MIN_SIMILARITY=0.55
IMAGE_MATCH_TOP_K=4
