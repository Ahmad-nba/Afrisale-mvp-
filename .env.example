# Copy to .env and fill in values

DATABASE_URL=sqlite:///./afrisale.db

# Vertex AI (GCP inference path)
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCP_MODEL=gemini-2.5-flash
# Absolute path to service account json key (or use gcloud ADC login)
GOOGLE_APPLICATION_CREDENTIALS=

# Normalized phone matching inbound webhook "from" (include country code, e.g. +256...)
OWNER_PHONE=

# Africa's Talking (optional for local dev — use SKIP_SMS_SEND=true in .env to log only)
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=
# AT_BASE_URL=https://api.africastalking.com/version1/messaging

# Gemini model id (default matches plan)
GEMINI_MODEL=gemini-2.5-flash

# LLM settings
LLM_TIMEOUT_SECONDS=30
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BACKOFF_SECONDS=0.8

# If true, outbound SMS is logged instead of sent
SKIP_SMS_SEND=false

# Twilio WhatsApp (inbound POST /api/webhook/whatsapp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox default; override for production WhatsApp sender
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Cloud Storage bucket for catalog and inbound media
GCS_BUCKET_PRODUCTS=
GCS_SIGNED_URL_TTL_SECONDS=86400

# Vertex AI multimodal embedding model (used to vectorize images and text)
VERTEX_VECTOR_DIMENSIONS=1408
VERTEX_EMBEDDING_MODEL=multimodalembedding@001

# Deprecated: not read by the local cosine-similarity search path.
# Kept here only so existing .env files continue to load. Safe to remove.
VERTEX_VECTOR_INDEX_ID=
VERTEX_VECTOR_INDEX_ENDPOINT_ID=
VERTEX_VECTOR_DEPLOYED_INDEX_ID=

# Inbound image limits
IMAGE_MAX_BYTES=10485760
IMAGE_ALLOWED_MIMES=image/jpeg,image/png,image/webp,image/heic,image/heif

# Image matching thresholds
# Multimodal embeddings cluster text and images separately, so cross-modal
# (text query -> image vector) cosines are much lower than intra-modal
# (image -> image) cosines. Two thresholds; tune empirically.
#   _IMAGE: image-to-image (when the user sends a photo).
#   _TEXT:  text-to-image (when the user types a description).
IMAGE_MATCH_MIN_SIMILARITY=0.30
IMAGE_MATCH_MIN_SIMILARITY_IMAGE=0.30
IMAGE_MATCH_MIN_SIMILARITY_TEXT=0.06
IMAGE_MATCH_TOP_K=4

# Seller MVP
# Single shared bearer token gating the /api/seller/* routes and embedded by
# the agent into the WhatsApp links it sends the seller (e.g. /seller/upload?t=...).
SELLER_ACCESS_TOKEN=
# Public base URL of the Next.js frontend. Use the dev server URL during MVP.
SELLER_BASE_URL=http://localhost:3000
# Window over which seller order notifications are batched (seconds).
SELLER_NOTIFICATION_WINDOW_SECONDS=300
