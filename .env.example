# Copy to .env and fill in values

DATABASE_URL=sqlite:///./afrisale.db

# Google AI Studio key for Gemini
GOOGLE_API_KEY=

# Normalized phone matching inbound webhook "from" (include country code, e.g. +256...)
OWNER_PHONE=

# Africa's Talking (optional for local dev — use SKIP_SMS_SEND=true in .env to log only)
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=
# AT_BASE_URL=https://api.africastalking.com/version1/messaging

# Gemini model id (default matches plan)
GEMINI_MODEL=gemini-2.5-flash

# If true, outbound SMS is logged instead of sent
SKIP_SMS_SEND=false

# Twilio WhatsApp (inbound POST /api/webhook/whatsapp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox default; override for production WhatsApp sender
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
